<%- include('../_legal_start', { title: 'Контакты' }) %>
  <h1 class="text-2xl font-bold mb-4">Контакты</h1>
  <p>
    <%= s.legal_entity_type %>: <strong><%= s.legal_name || '[ФИО / Название]' %></strong><br>
    ИНН: <%= s.legal_inn || '[ИНН]' %><br>
    <% if (s.legal_ogrn) { %>ОГРНИП / ОГРН: <%= s.legal_ogrn %><br><% } %>
    Email: <% if (s.legal_email) { %><a href="mailto:<%= s.legal_email %>" class="text-brand-600"><%= s.legal_email %></a><% } else { %>[email]<% } %><br>
    Телефон: <%= s.legal_phone || '[телефон]' %><br>
    <% if (s.legal_address) { %>Адрес: <%= s.legal_address %><% } %>
  </p>
<%- include('../_legal_end') %>
