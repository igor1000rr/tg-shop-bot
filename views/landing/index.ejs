<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Cartoon Academy — Оживляем истории. Создаём мультфильмы с помощью AI</title>
  <meta name="description" content="Обучение созданию мультфильмов и анимации с помощью искусственного интеллекта. От идеи до готового ролика.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['"Playfair Display"', 'serif'],
            sans: ['Inter', 'sans-serif']
          },
          colors: {
            stage:  { 950: '#0a0608', 900: '#120a0e', 800: '#1a0f15' },
            blood:  { 500: '#a83242', 600: '#7d2533', 700: '#5a1a25' },
            gold:   { 400: '#d4a857', 500: '#b8893a', 600: '#8c6628' }
          }
        }
      }
    }
  </script>
  <style>
    html { scroll-behavior: smooth; }
    body { background: #0a0608; }

    /* Прожекторы */
    .spot-light::before, .spot-light::after {
      content: ''; position: absolute; top: -20%; width: 60vw; height: 80vh;
      background: radial-gradient(ellipse at center, rgba(212, 168, 87, 0.18) 0%, transparent 60%);
      pointer-events: none; z-index: 0;
    }
    .spot-light::before { left: -15%; transform: rotate(-12deg); }
    .spot-light::after  { right: -15%; transform: rotate(12deg); }

    /* Бархатный занавес по краям сцены */
    .curtain {
      background:
        repeating-linear-gradient(90deg, rgba(125, 37, 51, 0.95) 0px, rgba(90, 26, 37, 0.95) 18px, rgba(125, 37, 51, 0.95) 36px),
        linear-gradient(180deg, rgba(168, 50, 66, 1) 0%, rgba(90, 26, 37, 1) 100%);
      box-shadow: inset 0 -40px 80px rgba(0,0,0,0.6);
    }

    /* Шум-текстура плёнки */
    .film-grain::after {
      content:''; position:absolute; inset:0; pointer-events:none; opacity:.08; mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    }

    /* Марионетка — раскачка */
    .puppet {
      transform-origin: 50% 0%;
      animation: sway 4s ease-in-out infinite;
    }
    .puppet.p2 { animation: sway 5s ease-in-out infinite -1s; }
    .puppet.p3 { animation: sway 3.6s ease-in-out infinite -2s; }
    .puppet.p4 { animation: sway 4.8s ease-in-out infinite -0.5s; }

    @keyframes sway {
      0%, 100% { transform: rotate(-4deg) translateY(0); }
      50%      { transform: rotate(4deg) translateY(-8px); }
    }

    /* Рука кукловода */
    .puppet-master {
      animation: hand-move 6s ease-in-out infinite;
      transform-origin: 50% 0;
    }
    @keyframes hand-move {
      0%, 100% { transform: translateX(-2%) rotate(-1deg); }
      50%      { transform: translateX(2%)  rotate(1deg); }
    }

    /* Нити — лёгкие покачивания */
    .string { stroke: rgba(255, 240, 200, 0.35); stroke-width: 0.8; }

    /* Появление секций */
    [data-reveal] {
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    [data-reveal].in { opacity: 1; transform: translateY(0); }

    /* CTA кнопка */
    .cta-glow {
      box-shadow: 0 0 0 0 rgba(212, 168, 87, 0.5);
      animation: pulse 2.5s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(212, 168, 87, 0.5); }
      50%      { box-shadow: 0 0 0 18px rgba(212, 168, 87, 0); }
    }
  </style>
</head>
<body class="font-sans text-stone-200 antialiased overflow-x-hidden">

<!-- ============ HERO ============ -->
<section class="relative min-h-screen overflow-hidden spot-light film-grain">

  <!-- Боковые занавесы -->
  <div class="curtain absolute left-0 top-0 h-full w-[12vw] z-10 hidden md:block"></div>
  <div class="curtain absolute right-0 top-0 h-full w-[12vw] z-10 hidden md:block"></div>

  <!-- Шапка -->
  <header class="relative z-20 flex items-center justify-between px-6 md:px-[14vw] py-6">
    <div class="flex items-center gap-2">
      <span class="font-serif text-xl tracking-wide text-gold-400">Cartoon</span>
      <span class="font-serif text-xl font-bold text-stone-100">Academy</span>
    </div>
    <nav class="hidden md:flex items-center gap-8 text-sm text-stone-400">
      <a href="#program" class="hover:text-gold-400 transition">Программа</a>
      <a href="#reviews" class="hover:text-gold-400 transition">Отзывы</a>
      <a href="#contacts" class="hover:text-gold-400 transition">Контакты</a>
    </nav>
    <a href="<%= botUrl %>" target="_blank" class="text-sm bg-stone-100 text-stage-900 px-4 py-2 rounded-full font-medium hover:bg-gold-400 transition">Записаться</a>
  </header>

  <!-- Куклы -->
  <div class="relative z-10 px-6 md:px-[14vw] mt-4 md:mt-0">
    <svg viewBox="0 0 1200 520" class="w-full h-auto" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <defs>
        <linearGradient id="dollGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"  stop-color="#f5d7b0"/>
          <stop offset="100%" stop-color="#d6a878"/>
        </linearGradient>
        <linearGradient id="dressRed" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#c44558"/>
          <stop offset="100%" stop-color="#7d2533"/>
        </linearGradient>
        <linearGradient id="dressBlue" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#2d4a7a"/>
          <stop offset="100%" stop-color="#1a2d4a"/>
        </linearGradient>
        <linearGradient id="dressGold" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#d4a857"/>
          <stop offset="100%" stop-color="#8c6628"/>
        </linearGradient>
        <linearGradient id="dressGreen" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#3d6e4a"/>
          <stop offset="100%" stop-color="#1f3d28"/>
        </linearGradient>
      </defs>

      <!-- Перекладина кукловода + рука -->
      <g class="puppet-master">
        <line x1="100" y1="30" x2="1100" y2="30" stroke="#3a2520" stroke-width="6"/>
        <line x1="100" y1="30" x2="1100" y2="30" stroke="#5a3a30" stroke-width="2"/>
        <!-- Рука -->
        <g transform="translate(560, 0)">
          <path d="M 0 0 Q 20 -20 50 -10 Q 80 0 90 30 L 80 70 Q 60 80 40 70 L 20 60 Z"
                fill="#d4a87a" stroke="#7d5a42" stroke-width="1.5"/>
          <path d="M 35 -5 L 55 -45" stroke="#d4a87a" stroke-width="10" stroke-linecap="round"/>
          <path d="M 55 -45 L 60 -120" stroke="#d4a87a" stroke-width="14" stroke-linecap="round"/>
          <path d="M 60 -120 L 60 -180" stroke="#2a1a1a" stroke-width="16" stroke-linecap="round" opacity="0.6"/>
        </g>
      </g>

      <!-- Кукла 1 -->
      <g class="puppet" transform="translate(180, 30)">
        <line class="string" x1="30" y1="0" x2="30" y2="110"/>
        <line class="string" x1="-10" y1="0" x2="0" y2="180"/>
        <line class="string" x1="70" y1="0" x2="60" y2="180"/>
        <line class="string" x1="15" y1="0" x2="15" y2="320"/>
        <line class="string" x1="45" y1="0" x2="45" y2="320"/>
        <circle cx="30" cy="140" r="32" fill="url(#dollGrad)" stroke="#7d5a42" stroke-width="1.5"/>
        <circle cx="22" cy="138" r="3" fill="#2a1a1a"/>
        <circle cx="38" cy="138" r="3" fill="#2a1a1a"/>
        <ellipse cx="22" cy="148" rx="3" ry="2" fill="#d4868a" opacity="0.7"/>
        <ellipse cx="38" cy="148" rx="3" ry="2" fill="#d4868a" opacity="0.7"/>
        <path d="M 22 156 Q 30 162 38 156" stroke="#7d2533" stroke-width="1.5" fill="none"/>
        <path d="M 0 170 L 60 170 L 70 280 L -10 280 Z" fill="url(#dressRed)" stroke="#5a1a25" stroke-width="1"/>
        <line x1="0" y1="180" x2="-20" y2="250" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="60" y1="180" x2="80" y2="250" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="15" y1="280" x2="15" y2="330" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <line x1="45" y1="280" x2="45" y2="330" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <ellipse cx="15" cy="335" rx="10" ry="5" fill="#2a1a1a"/>
        <ellipse cx="45" cy="335" rx="10" ry="5" fill="#2a1a1a"/>
      </g>

      <!-- Кукла 2 -->
      <g class="puppet p2" transform="translate(420, 30)">
        <line class="string" x1="30" y1="0" x2="30" y2="100"/>
        <line class="string" x1="-10" y1="0" x2="0" y2="180"/>
        <line class="string" x1="70" y1="0" x2="60" y2="180"/>
        <line class="string" x1="15" y1="0" x2="15" y2="320"/>
        <line class="string" x1="45" y1="0" x2="45" y2="320"/>
        <circle cx="30" cy="130" r="30" fill="url(#dollGrad)" stroke="#7d5a42" stroke-width="1.5"/>
        <circle cx="22" cy="128" r="3" fill="#2a1a1a"/>
        <circle cx="38" cy="128" r="3" fill="#2a1a1a"/>
        <path d="M 22 146 Q 30 142 38 146" stroke="#7d2533" stroke-width="1.5" fill="none"/>
        <path d="M 0 158 L 60 158 L 70 270 L -10 270 Z" fill="url(#dressBlue)" stroke="#1a2d4a" stroke-width="1"/>
        <line x1="0" y1="170" x2="-25" y2="230" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="60" y1="170" x2="85" y2="230" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="15" y1="270" x2="15" y2="325" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <line x1="45" y1="270" x2="45" y2="325" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <ellipse cx="15" cy="330" rx="10" ry="5" fill="#2a1a1a"/>
        <ellipse cx="45" cy="330" rx="10" ry="5" fill="#2a1a1a"/>
      </g>

      <!-- Кукла 3 -->
      <g class="puppet p3" transform="translate(680, 30)">
        <line class="string" x1="30" y1="0" x2="30" y2="110"/>
        <line class="string" x1="-10" y1="0" x2="0" y2="180"/>
        <line class="string" x1="70" y1="0" x2="60" y2="180"/>
        <line class="string" x1="15" y1="0" x2="15" y2="320"/>
        <line class="string" x1="45" y1="0" x2="45" y2="320"/>
        <circle cx="30" cy="140" r="32" fill="url(#dollGrad)" stroke="#7d5a42" stroke-width="1.5"/>
        <circle cx="22" cy="138" r="3" fill="#2a1a1a"/>
        <circle cx="38" cy="138" r="3" fill="#2a1a1a"/>
        <path d="M 22 156 Q 30 160 38 156" stroke="#7d2533" stroke-width="1.5" fill="none"/>
        <path d="M 0 170 L 60 170 L 70 280 L -10 280 Z" fill="url(#dressGold)" stroke="#8c6628" stroke-width="1"/>
        <line x1="0" y1="180" x2="-20" y2="250" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="60" y1="180" x2="80" y2="250" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="15" y1="280" x2="15" y2="330" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <line x1="45" y1="280" x2="45" y2="330" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <ellipse cx="15" cy="335" rx="10" ry="5" fill="#2a1a1a"/>
        <ellipse cx="45" cy="335" rx="10" ry="5" fill="#2a1a1a"/>
      </g>

      <!-- Кукла 4 -->
      <g class="puppet p4" transform="translate(920, 30)">
        <line class="string" x1="30" y1="0" x2="30" y2="100"/>
        <line class="string" x1="-10" y1="0" x2="0" y2="180"/>
        <line class="string" x1="70" y1="0" x2="60" y2="180"/>
        <line class="string" x1="15" y1="0" x2="15" y2="320"/>
        <line class="string" x1="45" y1="0" x2="45" y2="320"/>
        <circle cx="30" cy="130" r="30" fill="url(#dollGrad)" stroke="#7d5a42" stroke-width="1.5"/>
        <circle cx="22" cy="128" r="3" fill="#2a1a1a"/>
        <circle cx="38" cy="128" r="3" fill="#2a1a1a"/>
        <path d="M 22 146 Q 30 142 38 146" stroke="#7d2533" stroke-width="1.5" fill="none"/>
        <path d="M 0 158 L 60 158 L 70 270 L -10 270 Z" fill="url(#dressGreen)" stroke="#1f3d28" stroke-width="1"/>
        <line x1="0" y1="170" x2="-25" y2="230" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="60" y1="170" x2="85" y2="230" stroke="url(#dollGrad)" stroke-width="8" stroke-linecap="round"/>
        <line x1="15" y1="270" x2="15" y2="325" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <line x1="45" y1="270" x2="45" y2="325" stroke="url(#dollGrad)" stroke-width="9" stroke-linecap="round"/>
        <ellipse cx="15" cy="330" rx="10" ry="5" fill="#2a1a1a"/>
        <ellipse cx="45" cy="330" rx="10" ry="5" fill="#2a1a1a"/>
      </g>
    </svg>
  </div>

  <!-- Заголовок под куклами -->
  <div class="relative z-20 px-6 md:px-[14vw] pb-20 md:pb-32 text-center">
    <div class="font-serif text-stone-100 text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[0.95]">
      Cartoon <span class="text-gold-400 italic">Academy</span>
    </div>
    <p class="mt-6 text-stone-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
      Оживляем истории. Создаём мультфильмы и анимацию с помощью искусственного интеллекта — от первой идеи до готового ролика.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 items-center justify-center">
      <a href="<%= botUrl %>" target="_blank"
         class="cta-glow inline-flex items-center gap-3 bg-gold-400 hover:bg-gold-500 text-stage-950 font-semibold px-8 py-4 rounded-full text-lg transition">
        Начать обучение →
      </a>
      <a href="#program" class="text-stone-300 hover:text-gold-400 transition text-base">Программа курса</a>
    </div>
  </div>
</section>

<!-- ============ PROGRAM ============ -->
<section id="program" class="relative py-24 md:py-32 px-6 md:px-[14vw]" data-reveal>
  <div class="text-center mb-16">
    <div class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">Программа</div>
    <h2 class="font-serif text-4xl md:text-5xl text-stone-100">Чему научим</h2>
    <p class="text-stone-400 mt-4 max-w-xl mx-auto">6 модулей — от идеи до готового мультфильма на AI</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <%
      const modules = [
        { n: '01', t: 'Сценарий и идея',          d: 'Как придумывать сюжет, писать диалоги и раскадровывать идеи в полноценные истории.' },
        { n: '02', t: 'Персонажи в Midjourney',   d: 'Создание узнаваемых героев, консистентных поз и эмоций. Промпт-инжиниринг для иллюстраторов.' },
        { n: '03', t: 'Анимация в Runway & Kling',   d: 'Оживляем статичные кадры. Image-to-video, камера, переходы и лип-синк.' },
        { n: '04', t: 'Озвучка и музыка',         d: 'Голоса персонажей в ElevenLabs, AI-музыка в Suno, звуковые эффекты и синхронизация.' },
        { n: '05', t: 'Монтаж и финал',           d: 'Собираем всё в CapCut/DaVinci. Колоркоррекция, ритм, финальный рендер.' },
        { n: '06', t: 'Монетизация',            d: 'Куда публиковать ролики, как оформлять канал, как привлекать заказчиков и рекламодателей.' }
      ];
    %>
    <% modules.forEach(function(m) { %>
      <div class="group relative bg-gradient-to-br from-stage-900 to-stage-800 border border-stone-800 rounded-2xl p-7 hover:border-gold-400/40 transition">
        <div class="font-serif text-5xl text-gold-400/60 group-hover:text-gold-400 transition"><%= m.n %></div>
        <h3 class="font-serif text-xl text-stone-100 mt-3"><%= m.t %></h3>
        <p class="text-stone-400 text-sm leading-relaxed mt-3"><%= m.d %></p>
      </div>
    <% }) %>
  </div>
</section>

<!-- ============ REVIEWS ============ -->
<section id="reviews" class="relative py-24 md:py-32 px-6 md:px-[14vw] bg-stage-900/40" data-reveal>
  <div class="text-center mb-16">
    <div class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">Отзывы</div>
    <h2 class="font-serif text-4xl md:text-5xl text-stone-100">Что говорят ученики</h2>
    <p class="text-stone-500 mt-4 max-w-xl mx-auto text-sm italic">Реальные отзывы появятся здесь после запуска первых потоков.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <%
      const reviews = [
        { n: 'Мария К.', r: 'До курса пробовала сама — время уходило в пустоту. За месяц выпустила первый мульт и набрала 12к подписчиков.' },
        { n: 'Алексей Д.', r: 'Мыслил, что нужно уметь рисовать. Оказалось — нужно уметь видеть историю. Ребята разложили всё по полочкам.' },
        { n: 'Елена С.', r: 'Первый заказ на фрилансе пришёл через две недели после окончания курса. Бюджет в 50к, время работы 4 дня.' },
        { n: 'Дмитрий П.', r: 'Для моего ребёнка создали с женой мультфильм с ним в главной роли. Реакция — бесценна.' },
        { n: 'Анна М.', r: 'Никогда не думала что смогу сделать мультфильм сама. Минимум воды, максимум практики.' },
        { n: 'Вадим Л.', r: 'Начал продавать ролики рекламным агентствам — окупил курс за первый месяц. Спасибо за конкретику.' }
      ];
    %>
    <% reviews.forEach(function(r) { %>
      <div class="bg-stage-800/60 border border-stone-800 rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold-400 to-blood-600 flex items-center justify-center font-serif text-stage-950 font-bold"><%= r.n.charAt(0) %></div>
          <div>
            <div class="text-stone-100 text-sm font-medium"><%= r.n %></div>
            <div class="text-gold-400 text-xs">★★★★★</div>
          </div>
        </div>
        <p class="text-stone-400 text-sm leading-relaxed italic">«<%= r.r %>»</p>
      </div>
    <% }) %>
  </div>
</section>

<!-- ============ CTA ============ -->
<section class="relative py-24 md:py-32 px-6 md:px-[14vw] text-center spot-light" data-reveal>
  <h2 class="font-serif text-4xl md:text-6xl text-stone-100 leading-tight">
    Готов создать <br/>
    <span class="text-gold-400 italic">свой первый мультфильм?</span>
  </h2>
  <p class="text-stone-400 mt-6 max-w-xl mx-auto">
    Доступ в закрытое сообщество, пошаговые уроки и обратная связь по вашим работам.
  </p>
  <a href="<%= botUrl %>" target="_blank"
     class="cta-glow inline-flex items-center gap-3 mt-10 bg-gold-400 hover:bg-gold-500 text-stage-950 font-semibold px-10 py-5 rounded-full text-lg transition">
    Открыть Telegram-бот →
  </a>
</section>

<!-- ============ FOOTER ============ -->
<footer id="contacts" class="relative border-t border-stone-900 py-12 px-6 md:px-[14vw]">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <span class="font-serif text-lg text-gold-400">Cartoon</span>
        <span class="font-serif text-lg font-bold text-stone-100">Academy</span>
      </div>
      <p class="text-stone-500 text-sm leading-relaxed">Обучение созданию мультфильмов и анимации с помощью AI.</p>
    </div>
    <div>
      <div class="text-stone-100 text-sm font-medium mb-3">Навигация</div>
      <div class="space-y-2 text-sm">
        <a href="#program" class="block text-stone-400 hover:text-gold-400 transition">Программа</a>
        <a href="#reviews" class="block text-stone-400 hover:text-gold-400 transition">Отзывы</a>
