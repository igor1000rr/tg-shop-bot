<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'tg-shop-bot' %> · Админка</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50:'#eff6ff', 100:'#dbeafe', 500:'#3b82f6', 600:'#2563eb', 700:'#1d4ed8', 900:'#1e3a8a' }
          }
        }
      }
    }
  </script>
  <style>
    [x-cloak] { display: none !important; }
  </style>
</head>
<body class="bg-slate-100 text-slate-900 min-h-screen">
<div class="flex min-h-screen">
  <!-- Sidebar -->
  <aside class="w-64 bg-slate-900 text-slate-100 flex flex-col">
    <div class="p-6 border-b border-slate-800">
      <div class="text-lg font-semibold">🛍 tg-shop-bot</div>
      <div class="text-xs text-slate-400 mt-1">админ-панель</div>
    </div>
    <nav class="flex-1 p-4 space-y-1">
      <% var p = typeof page !== 'undefined' ? page : ''; %>
      <a href="/admin"          class="flex items-center gap-3 px-3 py-2 rounded-lg <%= p==='dashboard' ? 'bg-brand-600 text-white' : 'text-slate-300 hover:bg-slate-800' %>">
        <span>📊</span> <span>Дашборд</span>
      </a>
      <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2 rounded-lg <%= p==='settings'  ? 'bg-brand-600 text-white' : 'text-slate-300 hover:bg-slate-800' %>">
        <span>⚙️</span> <span>Настройки</span>
      </a>
      <a href="/admin/payments" class="flex items-center gap-3 px-3 py-2 rounded-lg <%= p==='payments'  ? 'bg-brand-600 text-white' : 'text-slate-300 hover:bg-slate-800' %>">
        <span>💰</span> <span>Платежи</span>
      </a>
      <div class="border-t border-slate-800 my-3"></div>
      <a href="/terms"   target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-slate-800 text-sm">
        <span>📜</span> <span>Оферта</span>
      </a>
      <a href="/privacy" target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-slate-800 text-sm">
        <span>🔒</span> <span>Политика</span>
      </a>
      <a href="/refund"  target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-slate-800 text-sm">
        <span>↩️</span> <span>Возврат</span>
      </a>
    </nav>
    <div class="p-4 border-t border-slate-800">
      <a href="/admin/logout" class="flex items-center gap-2 text-sm text-slate-400 hover:text-white">
        <span>↪️</span> <span>Выйти</span>
      </a>
    </div>
  </aside>

  <!-- Content -->
  <main class="flex-1 overflow-x-auto">
    <div class="p-8 max-w-6xl mx-auto">
