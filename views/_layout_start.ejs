<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'tg-shop-bot' %> · Админка</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50:'#eff6ff', 100:'#dbeafe', 500:'#3b82f6', 600:'#2563eb', 700:'#1d4ed8', 900:'#1e3a8a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-slate-100 text-slate-900 min-h-screen antialiased">
<div class="flex min-h-screen">

  <!-- Sidebar -->
  <aside class="w-64 bg-slate-900 text-slate-100 flex flex-col shrink-0">
    <div class="px-6 py-5 border-b border-slate-800">
      <div class="text-base font-semibold flex items-center gap-2">
        <span>🛍</span> <span>tg-shop-bot</span>
      </div>
      <div class="text-xs text-slate-500 mt-0.5">админ-панель</div>
    </div>

    <nav class="flex-1 p-3 space-y-1">
      <% var p = typeof page !== 'undefined' ? page : ''; %>
      <a href="/admin"          class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm <%= p==='dashboard' ? 'bg-brand-600 text-white shadow-sm' : 'text-slate-300 hover:bg-slate-800 hover:text-white' %>">
        <span class="w-5">📊</span> <span>Дашборд</span>
      </a>
      <a href="/admin/users"    class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm <%= p==='users'     ? 'bg-brand-600 text-white shadow-sm' : 'text-slate-300 hover:bg-slate-800 hover:text-white' %>">
        <span class="w-5">👥</span> <span>Пользователи</span>
      </a>
      <a href="/admin/payments" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm <%= p==='payments'  ? 'bg-brand-600 text-white shadow-sm' : 'text-slate-300 hover:bg-slate-800 hover:text-white' %>">
        <span class="w-5">💰</span> <span>Платежи</span>
      </a>
      <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm <%= p==='settings'  ? 'bg-brand-600 text-white shadow-sm' : 'text-slate-300 hover:bg-slate-800 hover:text-white' %>">
        <span class="w-5">⚙️</span> <span>Настройки</span>
      </a>
    </nav>

    <div class="px-3 py-3 border-t border-slate-800">
      <a href="/admin/logout" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-400 hover:bg-slate-800 hover:text-white">
        <span>↪️</span> <span>Выйти</span>
      </a>
    </div>
  </aside>

  <!-- Content -->
  <main class="flex-1 min-w-0">
    <div class="p-8 max-w-7xl mx-auto">
