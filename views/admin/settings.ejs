<%- include('../_layout_start', { title: 'Настройки', page: page }) %>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-slate-900">Настройки</h1>
    <p class="text-slate-500 text-sm mt-1">Изменения сразу применяются. Секреты оставьте пустыми чтобы не менять.</p>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm flex items-center gap-2">
      ✓ Настройки сохранены
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <!-- Tabs -->
    <div class="flex border-b border-slate-200 overflow-x-auto bg-slate-50">
      <% groups.forEach(function(g){ %>
        <button type="button" data-tab="<%= g.id %>"
                class="tab-btn px-5 py-3 text-sm font-medium whitespace-nowrap border-b-2 <%= activeTab===g.id ? 'border-brand-600 text-brand-700 bg-white' : 'border-transparent text-slate-600 hover:text-slate-900' %>">
          <%= g.label %>
        </button>
      <% }); %>
    </div>

    <form method="POST" action="/admin/settings" class="p-6">
      <input type="hidden" name="__tab" id="__tab" value="<%= activeTab %>">

      <% groups.forEach(function(g){ %>
        <div class="tab-panel space-y-5" data-panel="<%= g.id %>" <%= activeTab===g.id ? '' : 'style="display:none"' %>>
          <% meta.filter(function(m){ return m.group === g.id }).forEach(function(m){ %>
            <div>
              <label for="<%= m.key %>" class="block text-sm font-medium text-slate-700 mb-1.5">
                <%= m.label %>
                <% if (secretKeys.has(m.key)) { %>
                  <span class="text-slate-400 font-normal">· оставьте пустым чтобы не менять</span>
                <% } %>
              </label>

              <% if (m.type === 'textarea') { %>
                <textarea name="<%= m.key %>" id="<%= m.key %>" rows="3"
                          class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"><%= settings[m.key] || '' %></textarea>
              <% } else if (m.type === 'password') { %>
                <input type="password" name="<%= m.key %>" id="<%= m.key %>" value="" autocomplete="new-password"
                       placeholder="<%= settings[m.key] ? '•••••••• (задано)' : 'не задано' %>"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm font-mono">
              <% } else if (m.type === 'checkbox') { %>
                <input type="hidden" name="<%= m.key %>" value="0">
                <label class="inline-flex items-center gap-2 text-sm">
                  <input type="checkbox" name="<%= m.key %>" value="1" <%= settings[m.key]==='1'?'checked':'' %>
                         class="w-4 h-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500">
                  <span class="text-slate-700">включено</span>
                </label>
              <% } else { %>
                <input type="text" name="<%= m.key %>" id="<%= m.key %>" value="<%= settings[m.key] || '' %>"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
              <% } %>
            </div>
          <% }); %>
        </div>
      <% }); %>

      <div class="mt-8 pt-5 border-t border-slate-200 flex items-center justify-end gap-3">
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white font-medium px-5 py-2.5 rounded-lg">
          Сохранить
        </button>
      </div>
    </form>
  </div>

<script>
(function() {
  const buttons = document.querySelectorAll('.tab-btn');
  const panels  = document.querySelectorAll('.tab-panel');
  const tabInput = document.getElementById('__tab');

  buttons.forEach(btn => btn.addEventListener('click', () => {
    const id = btn.dataset.tab;
    buttons.forEach(b => {
      const active = b.dataset.tab === id;
      b.classList.toggle('border-brand-600', active);
      b.classList.toggle('text-brand-700', active);
      b.classList.toggle('bg-white', active);
      b.classList.toggle('border-transparent', !active);
      b.classList.toggle('text-slate-600', !active);
    });
    panels.forEach(p => p.style.display = (p.dataset.panel === id ? '' : 'none'));
    tabInput.value = id;
    history.replaceState(null, '', '/admin/settings?tab=' + id);
  }));
})();
</script>

<%- include('../_layout_end') %>
