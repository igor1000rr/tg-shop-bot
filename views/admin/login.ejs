<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Вход · tg-shop-bot</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-brand-900 min-h-screen flex items-center justify-center p-6">
  <div class="bg-white/95 backdrop-blur rounded-2xl shadow-2xl p-10 w-full max-w-md">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🛍</div>
      <h1 class="text-2xl font-bold text-slate-900">tg-shop-bot</h1>
      <p class="text-sm text-slate-500 mt-1">админ-панель</p>
    </div>

    <% if (error) { %>
      <div class="mb-5 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">
        ⚠️ <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/admin/login" class="space-y-5">
      <input type="hidden" name="from" value="<%= from %>">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Логин</label>
        <input type="text" name="login" autocomplete="username" required autofocus
               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Пароль</label>
        <input type="password" name="password" autocomplete="current-password" required
               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <button type="submit"
              class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-2.5 rounded-lg transition">
        Войти
      </button>
    </form>

    <p class="text-center text-xs text-slate-400 mt-6">Данные для входа задаются в .env (ADMIN_LOGIN / ADMIN_PASSWORD)</p>
  </div>
</body>
</html>
