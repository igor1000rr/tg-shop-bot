<!DOCTYPE html>
<html lang="ru"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= typeof title !== 'undefined' ? title : 'tg-shop-bot' %></title>
<style>
  body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;max-width:1000px;margin:2rem auto;padding:0 1rem;color:#222;line-height:1.5}
  nav a{margin-right:1rem;text-decoration:none;color:#0366d6}
  table{border-collapse:collapse;width:100%;margin-top:1rem;font-size:14px}
  th,td{border:1px solid #ddd;padding:6px 10px;text-align:left}
  th{background:#f4f4f4}
  form label{display:block;font-weight:600;margin-top:14px;font-size:13px;color:#444}
  input[type=text],input[type=number],input[type=url],textarea{width:100%;padding:8px;font-family:inherit;box-sizing:border-box;border:1px solid #ccc;border-radius:4px}
  textarea{min-height:70px;resize:vertical}
  button{padding:8px 16px;cursor:pointer;margin-top:14px;background:#0366d6;color:#fff;border:0;border-radius:4px;font-size:14px}
  button:hover{background:#024fa3}
  .status-paid{color:#0a0;font-weight:600}
  .status-failed{color:#c00}
  .status-pending{color:#888}
  .muted{color:#888;font-size:13px}
  .legal{max-width:760px}
  .legal h2{margin-top:1.4em}
  hr{border:0;border-top:1px solid #eee;margin:1rem 0}
</style>
</head><body>
<nav>
  <a href="/admin">📊 Дашборд</a>
  <a href="/admin/settings">⚙️ Настройки</a>
  <a href="/admin/payments">💰 Платежи</a>
  <a href="/terms" target="_blank">📜 Оферта</a>
  <a href="/privacy" target="_blank">🔒 Политика</a>
</nav>
<hr>
