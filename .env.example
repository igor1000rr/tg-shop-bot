# Telegram
BOT_TOKEN=
CHANNEL_ID=-1001234567890
LOG_CHAT_ID=

# Сервер — PUBLIC_URL ОБЯЗАТЕЛЕН, должен быть HTTPS с публичным SSL
# (Platega не принимает callback на HTTP, self-signed, локальные и приватные IP)
PORT=3000
PUBLIC_URL=https://bot.example.com

# Админка (basic auth)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme

# Platega
PLATEGA_SHOP_ID=
PLATEGA_SECRET=
PLATEGA_API_URL=https://app.platega.io
# Опционально: фиксированный метод оплаты (число из доки Platega — напр. 2 = СБП).
# Если пусто — используется страница с выбором всех доступных методов.
PLATEGA_PAYMENT_METHOD=

# CryptoBot
CRYPTOBOT_TOKEN=
CRYPTOBOT_API_URL=https://pay.crypt.bot/api

# Уведомления о накоплении крипты для вывода на Trust Wallet
# (в API CryptoBot нет прямого вывода на внешний адрес — вывод вручной через @CryptoBot)
WITHDRAW_WALLET=
WITHDRAW_NETWORK=TRC20
WITHDRAW_ASSET=USDT
WITHDRAW_THRESHOLD_USDT=50
WITHDRAW_CRON=0 3 * * *
